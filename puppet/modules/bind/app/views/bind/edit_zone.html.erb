<%= klass_menu("Edit DNS zone") %>

<% labelled_tabular_form_for :bind_zone, @bind_zone, :url => {:action=>'edit_zone'} do |f| -%>

  <p><%= f.error_messages %></p>

  <% if params[:master] == "false" or @bind_zone.master == false -%>
    <%= render :partial => 'bind_slave_zone', :locals => {:f => f} %>
  <% else -%>
    <%= render :partial => 'bind_zone', :locals => {:f => f} %>
  <% end -%>

  <%= submit_tag("Save")%><br />
  <%= link_to "Back", :action=>'configure', :id=>@klass %>

<% end -%>
